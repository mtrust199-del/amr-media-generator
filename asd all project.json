{
  "architecture": {
    "overview": "Unified AMR Media Project integrates Flask backend, UI components (Temp Mail, Video Publishing Dashboard, Automation Page) with n8n orchestration, OpenRouter/Qwen intelligence, and local automation via PyAutoGUI/Playwright.",
    "layers": {
      "presentation": ["Temp Mail Interface", "Video Publishing Dashboard", "Automation System Page", "AMR OMNI Command Center (dashboard.html)"],
      "orchestration": "n8n workflow engine",
      "intelligence": "OpenRouter/Qwen (Arabic command processing)",
      "automation": "PyAutoGUI/Playwright (OS & browser interaction)",
      "self_healing": "GitHub auto‑update service"
    },
    "integration_points": {
      "whatsapp_telegram_bridge": "n8n → Flask webhook /exec_endpoint",
      "dashboard_scheduling": "n8n → Flask scheduler API",
      "automation_page_triggers": "n8n → PyAutoGUI scripts",
      "intelligence_triggers": "OpenRouter → Flask command dispatcher",
      "dashboard_actions": "Glass‑morphism buttons → Flask /open‑folder, /auth/test"
    }
  },
  "github_sync": {
    "repository_url": "https://github.com/mtrust199-del/amr-media-generator",
    "default_branch": "main",
    "webhook_secret": "REPLACE_WITH_SECRET",
    "auto_update": true,
    "update_schedule": "every 6 hours (cron: '0 */6 * * *')",
    "update_process": [
      "git fetch origin",
      "git reset --hard origin/main",
      "python -m pip install -r requirements.txt",
      "systemctl restart amr-media.service || sudo service amr-media restart"
    ]
  },
  "n8n_webhook_endpoints": {
    "temp_mail": "http://localhost:5678/workflow/RneNoeIA8tVsH8PG/temp-mail",
